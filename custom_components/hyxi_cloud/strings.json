{
  "title": "HYXI Cloud",
  "config": {
    "step": {
      "user": {
        "title": "Connect to HYXI Cloud",
        "description": "Enter your **Developer API credentials (AK/SK)**. You can generate these at the [HYXIPOWER Developer Platform]({link}).\n\n**Note:** This requires a separate developer account. If your developer email differs from your app email, you must **Share your Plant** from the app to the developer email first.",
        "data": {
          "access_key": "Access Key (AK)",
          "secret_key": "Secret Key (SK)"
        }
      },
      "reauth_confirm": {
        "title": "Re-authenticate HYXI Cloud",
        "description": "Your Access Key or Secret Key is no longer valid. Please enter your new credentials to resume solar monitoring. You can find these at the [HYXIPOWER Developer Platform]({link}).",
        "data": {
          "access_key": "Access Key (AK)",
          "secret_key": "Secret Key (SK)"
        }
      }
    },
    "error": {
      "cannot_connect": "Failed to connect to HYXI servers",
      "invalid_auth": "Invalid Access Key or Secret Key",
      "unknown": "Unexpected error occurred"
    },
    "abort": {
      "already_configured": "This HYXI account is already configured.",
      "reauth_successful": "Re-authentication was successful"
    }
  },
  "options": {
    "step": {
      "init": {
        "title": "HYXI System Configuration",
        "description": "Adjust how your integration communicates with the HYXI Cloud.\n\n---",
        "data": {
          "update_interval": "Polling Interval (1-60 Minutes, Default: 5)",
          "back_discovery": "Enable discovery via alarms (Advanced)"
        }
      }
    }
  },
