  "config": {
    "step": {
      "user": {
        "title": "Mit HYXI Cloud verbinden",
        "description": "Geben Sie Ihre **Entwickler-API-Zugangsdaten (AK/SK)** ein. Sie können diese auf der [HYXIPOWER Developer Platform]({link}) generieren.\n\n**Hinweis:** Dies erfordert ein separates Entwicklerkonto. Wenn sich Ihre Entwickler-E-Mail von Ihrer App-E-Mail unterscheidet, müssen Sie Ihre Anlage zuerst über die App für die Entwickler-E-Mail **freigeben**.",
        "data": {
          "access_key": "Access Key (AK)",
          "secret_key": "Secret Key (SK)"
        }
      },
      "reauth_confirm": {
        "title": "HYXI Cloud erneut authentifizieren",
        "description": "Ihr Access Key oder Secret Key ist nicht mehr gültig. Bitte geben Sie Ihre neuen Anmeldedaten ein, um die Solarüberwachung fortzusetzen. Sie finden diese auf der [HYXIPOWER Developer Platform]({link}).",
        "data": {
          "access_key": "Access Key (AK)",
          "secret_key": "Secret Key (SK)"
        }
      }
    },
    "error": {
      "cannot_connect": "Verbindung zu den HYXI-Servern fehlgeschlagen",
