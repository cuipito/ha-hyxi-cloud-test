{
  "config": {
    "step": {
      "user": {
        "title": "Połącz z HYXI Cloud",
        "description": "Wprowadź swoje **poświadczenia API programisty (AK/SK)**. Możesz je wygenerować na [Platformie programistycznej HYXIPOWER]({link}).\n\n**Uwaga:** Wymagane jest oddzielne konto programisty. Jeśli Twój e-mail programisty różni się od e-maila w aplikacji, musisz najpierw **Udostępnić swój obiekt (Plant)** z aplikacji na e-mail programisty.",
        "data": {
          "access_key": "Klucz dostępu (AK)",
          "secret_key": "Tajny klucz (SK)"
        }
      },
      "reauth_confirm": {
        "title": "Ponowne uwierzytelnianie HYXI Cloud",
        "description": "Twój klucz dostępu lub tajny klucz jest już nieważny. Wprowadź nowe poświadczenia, aby wznowić monitorowanie instalacji solarnej. Możesz je znaleźć na [Platformie programistycznej HYXIPOWER]({link}).",
        "data": {
          "access_key": "Klucz dostępu (AK)",
          "secret_key": "Tajny klucz (SK)"
        }
      }
    },
    "error": {
      "cannot_connect": "Nie udało się połączyć z serwerami HYXI",
      "invalid_auth": "Nieprawidłowy klucz dostępu lub tajny klucz",
      "unknown": "Wystąpił nieoczekiwany błąd",
      "no_devices": "Nie znaleziono żadnych instalacji ani urządzeń. Jeśli Twój e-mail programisty różni się od e-maila w aplikacji, musisz najpierw udostępnić swoją instalację z aplikacji na e-mail programisty."
    },
    "abort": {
      "already_configured": "To konto HYXI jest już skonfigurowane.",
      "reauth_successful": "Ponowne uwierzytelnianie zakończyło się pomyślnie"
    }
  },
  "options": {
    "step": {
      "init": {
        "title": "Konfiguracja systemu HYXI",
        "description": "Dostosuj sposób komunikacji integracji z HYXI Cloud.\n\nJeśli sterowanie zostało zablokowane z powodu błędnego wykrycia VPP (np. normalny tryb pracy 16), zaznacz **Override VPP Lock**, aby je przywrócić.\n\n---",
        "data": {
          "update_interval": "Interwał odpytywania (1-60 minut, domyślnie: 5)",
          "back_discovery": "Włącz wykrywanie przez alarmy (zaawansowane)",
          "enable_battery_control": "Włącz kontrolę i ochronę urządzenia",
          "enable_energy_manager": "Enable Energy Manager Standalone (Beta)",
          "enable_realtime_push": "Enable Real-Time Webhook Push",
          "realtime_push_rate": "Push Update Frequency (milliseconds, range: 5000-3600000)",
          "realtime_push_url": "Custom Callback URL (optional, dynamic default)"
