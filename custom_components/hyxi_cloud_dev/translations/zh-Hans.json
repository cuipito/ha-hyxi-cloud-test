{
  "config": {
    "step": {
      "user": {
        "title": "连接到 HYXI Cloud",
        "description": "请输入您的 **开发者 API 凭据 (AK/SK)**。您可以在 [HYXIPOWER 开发者平台]({link}) 生成这些凭据。\n\n**注意：** 这需要一个单独的开发者账号。如果您的开发者邮箱与应用邮箱不同，您必须先通过应用将您的 **电站分享** 给开发者邮箱。",
        "data": {
          "access_key": "访问密钥 (AK)",
          "secret_key": "加密密钥 (SK)"
        }
      },
      "reauth_confirm": {
        "title": "重新认证 HYXI Cloud",
        "description": "您的访问密钥或加密密钥已过期。请输入新的凭据以恢复光伏监控。您可以在 [HYXIPOWER 开发者平台]({link}) 找到这些信息。",
        "data": {
          "access_key": "访问密钥 (AK)",
          "secret_key": "加密密钥 (SK)"
        }
      }
    },
    "error": {
      "cannot_connect": "连接 HYXI 服务器失败",
      "invalid_auth": "无效的访问密钥或加密密钥",
      "unknown": "发生未知错误"
    },
    "abort": {
      "already_configured": "该 HYXI 账号已配置。",
      "reauth_successful": "重新认证成功"
    }
